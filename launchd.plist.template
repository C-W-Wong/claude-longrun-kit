<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.claude.longrun-heartbeat</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__HOME__/.claude/hooks/long-run-os-heartbeat.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>11</integer><key>Minute</key><integer>6</integer></dict>
    <dict><key>Hour</key><integer>16</integer><key>Minute</key><integer>6</integer></dict>
    <dict><key>Hour</key><integer>21</integer><key>Minute</key><integer>6</integer></dict>
    <dict><key>Hour</key><integer>2</integer><key>Minute</key><integer>6</integer></dict>
    <dict><key>Hour</key><integer>7</integer><key>Minute</key><integer>6</integer></dict>
  </array>
</dict>
</plist>
